# ─────────────────────────────────────────────────────────────────────────────
# TournamentHub — Environment Variable Template
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000

# ─── USTA Connect API ─────────────────────────────────────────────────────────
# Obtain credentials by emailing ustaconnect@usta.com or visiting:
# https://ustadigital.atlassian.net/wiki/spaces/DEV/pages/742916315/
#
# OAuth 2.0 Client Credentials grant
USTA_CLIENT_ID=your_usta_client_id
USTA_CLIENT_SECRET=your_usta_client_secret

# Base URL for the USTA Connect API (confirm with USTA after access is granted)
USTA_API_BASE_URL=https://api.usta.com

# OAuth token endpoint (confirm with USTA after access is granted)
USTA_TOKEN_URL=https://identity.usta.com/oauth/token

# ─── ITF World Tennis Number (WTN) API ───────────────────────────────────────
# Request access via the ITF partner programme:
# https://docs.worldtennisnumber.com/
#
# After approval you will receive a JWT token and a provider ID.
ITF_JWT_TOKEN=your_itf_jwt_token
ITF_PROVIDER_ID=your_itf_provider_id

# GraphQL endpoint (from ITF WTN documentation)
ITF_API_URL=https://api.worldtennisnumber.com/graphql
